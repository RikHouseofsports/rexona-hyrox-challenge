# Server
PORT=3000
NODE_ENV=development

# Database path (use absolute path on Railway, e.g. /data/challenge.db)
DB_PATH=./challenge.db

# Admin interface password (hostess)
ADMIN_PASSWORD=changeme_admin

# Data export password (marketing team)
EXPORT_PASSWORD=changeme_export

# Session secret — generate a strong random value:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_this_with_64_char_random_hex
